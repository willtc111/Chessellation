{
	"name": "chessellation",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently \"npm run dev:frontend\" \"npm run dev:wasm\"",
		"dev:frontend": "vite dev",
		"dev:wasm": "cd rust-wasm && cargo watch -s \"wasm-pack build --target bundler --out-dir ../src/lib/wasm/\"",
		"build": "npm run build:frontend",
		"build:frontend": "wrangler types --check && vite build",
		"build:wasm": "cd rust-wasm && wasm-pack build --target bundler --out-dir ../src/lib/wasm/",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --diagnostic-sources js,svelte",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json  --diagnostic-sources js,svelte --watch",
		"format": "prettier --write . && npm run format:rust",
		"format:rust": "cd rust-wasm && cargo fmt",
		"lint": "prettier --check . && eslint .",
		"test": "npm run test:unit -- --run && npm run test:rust",
		"test:unit": "vitest",
		"test:rust": "cd rust-wasm && cargo test",
		"gen": "wrangler types"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@skeletonlabs/skeleton": "^4.15.2",
		"@skeletonlabs/skeleton-svelte": "^4.15.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"concurrently": "^9.2.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.0",
		"vite-plugin-wasm": "^3.6.0",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.81.0"
	},
	"dependencies": {
		"chart.js": "^4.5.1",
		"pixi.js": "^8.15.0"
	}
}
